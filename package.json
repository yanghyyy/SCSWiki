{
  "name": "scswiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vitepress dev docs --host 0.0.0.0",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules\" \"!docs/.vitepress/cache\" \"!docs/.vitepress/dist\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "contributors:generate": "tsx scripts/generate-contributors.ts",
    "validate:content": "tsx scripts/validate-content.ts",
    "check:links": "tsx scripts/check-internal-links.ts",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm lint:md && pnpm format && pnpm validate:content && pnpm check:links && pnpm test && pnpm build"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vitepress": "^1.6.4",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "markdown-it-katex": "^2.0.3",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9",
    "zod": "^3.25.76"
  }
}
